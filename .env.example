# Copy to .env and adjust. Required vars are validated at startup (app fails fast if missing).

# App
NODE_ENV=development
PORT=3000

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=task_manager

# Auth (used by later stories; required so config validates consistently)
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=1h
